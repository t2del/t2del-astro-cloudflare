---
import { Picture, } from 'astro:assets';
import { locale } from "@consts";
const {  url, image, title, slug, date, excerpt  } = Astro.props;
---
<article transition:name={`blog-card-${slug}`} class="rounded shadow-md text-slate-500 bg-white shadow-slate-200 overflow-hidden text-center m-2">
    <a href={url}>
        <Picture
            formats={[ 'webp']}
            class="aspect-video w-full object-cover"
            src={image}
            alt={title} 
            width={720}
            height={360}
            loading={"lazy"}
            sizes="(min-width:1280px) 25vw, (min-width:1024px) 33vw, (min-width:768px) 50vw, 100vw"
        />
    </a>
    <div class="p-4 sm:p-6">
    <span class="text-sm text-gray-700 dark:text-gray-500">
        <time datetime={date}>
        {new Date(date).toLocaleDateString(
            locale.date.locale,
            locale.date.options,
        )}
        </time>
    </span>
    
    <a href={url}>
        <h3 class="text-gray-900 dark:text-gray-800  mt-0.5 text-xl font-semibold" set:html={title}></h3>
    </a>
    <p class="text-gray-500 dark:text-gray-400 mt-2 line-clamp-3 text-sm/relaxed lg:hidden 2xl:block" set:html={excerpt}></p>
    </div>
</article>