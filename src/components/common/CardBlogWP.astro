---
import { Picture, } from 'astro:assets';
import { locale } from "@consts";
const {  url, image, title, slug, date, excerpt  } = Astro.props;
---
<article class="overflow-hidden rounded-lg shadow-sm transition hover:shadow-lg">
    <a href={url}>
        <Picture
            formats={[ 'webp']}
            class="aspect-video w-full object-cover"
            src={image}
            alt={title} 
            width={720}
            height={360}
            loading={"lazy"}
            sizes="(min-width:1024px) 33vw, (min-width:768px) 50vw, 100vw"
            style={`view-transition-name: vt-post-featured-image-${slug};`} 
        />
    </a>
    <div class="p-4 sm:p-6">
    <span class="text-sm text-gray-400 dark:text-gray-500">
        <time datetime={date}>
        {new Date(date).toLocaleDateString(
            locale.date.locale,
            locale.date.options,
        )}
        </time>
    </span>
    
    <a href={url}>
        <h3 class="text-gray-900 dark:text-white mt-0.5 text-lg font-semibold" set:html={title}></h3>
    </a>
    <p class="text-gray-500 dark:text-white mt-2 line-clamp-3 text-sm/relaxed " set:html={excerpt}></p>
    </div>
</article>