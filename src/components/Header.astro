---
import { Picture } from "astro:assets";
import Logo from "@/assets/denmac.png";
import NavbarMenuItems from "./navigation/NavbarMenuItems.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import SearchModal from "@/components/modals/SearchModal.astro";

import { config } from "../consts";
const isHome =
  Astro.url.pathname === config.base ||
  Astro.url.pathname === `${config.base}/`;
---

<div class="drawer">
  <input id="my-drawer-2" type="checkbox" class="drawer-toggle" />
  <div class="drawer-content flex flex-col bg-base-300 shadow">
    <!-- Navbar -->
    <div class="navbar  w-full mx-auto max-w-[140rem]">
      <div class=" lg:hidden navbar-start xs:flex-1 sm:flex-1 md:flex-1">
        <label for="my-drawer-2" aria-label="open sidebar" class="btn btn-square btn-ghost">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            class="inline-block h-6 w-6 stroke-current"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            ></path>
          </svg>
        </label>
      </div>
      <div class="navbar-start xs:flex-1 sm:flex-1 md:flex-1 flex justify-center lg:justify-start">
        <a
          href={`${config.base}/`}
          class="btn btn-ghost center text-xl lg:flex"
        >
          <Picture 
            src={Logo} 
            alt="Dennis Macapagal" 
            class="h4 w-20" width={120}
            height={60}
            loading={"lazy"} 
            />
        </a>
      </div>
      <div class="hidden flex-none lg:block navbar-center">
        <ul class="menu menu-horizontal">
          <NavbarMenuItems />
        </ul>
      </div>
      <div class="navbar-end xs:flex-1 sm:flex-1 md:flex-1">
        <SearchModal />
        <ThemeToggle class="btn bth-ghost" />
      </div>
    </div>

  </div>

  <div class="drawer-side">
    <label for="my-drawer-2" aria-label="close sidebar" class="drawer-overlay"></label>
    <div class=" bg-base-200 min-h-full w-80 ">
      <!-- Sidebar content here -->
       <a
          href={`${config.base}/`}
          class="flex w-[100%] p-2"
        >
          <Picture 
            src={Logo} 
            alt="Dennis Macapagal" 
            class="h4 w-20" width={160}
            height={60}
            loading={"lazy"} 
            />
        </a>
        <hr class="mt-[10px] mb-[10px] text-gray-100 dark:text-white">
        <ul class="menu bg-base-200 min-h-full w-[100%] p-0">
          <NavbarMenuItems />
        </ul>
    </div>
  </div>
</div>