---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { locale } from "@/consts";
import ContactFormNetlify  from "@/components/contact/ContactFormNetlify.astro";

const work = (
  await getCollection("workCollection", ({ data }) => data.draft !== true)
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const postsPerPage = 5;


const titleLayout = `T2del`;
const description = "Minimal and lightweight blog and portfolio.";

---
<Layout title={titleLayout} description={description} ga4={true} clarity={true} maxWidth={"1000px"}>
  <section class="animate-fade-down text-center">
      <iframe data-testid="embed-iframe" style="border-radius:12px" src="https://open.spotify.com/embed/playlist/1Z7Fquw35sXFKbPxGKwlg0?utm_source=generator&theme=0" width="100%" height="500" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
  </section>

  
</Layout>