---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { locale, skills, introduction } from "@/consts";
import ContactFormNetlify  from "@/components/contact/ContactFormNetlify.astro";
import ContactFormFormspree  from "@/components/contact/ContactFormFormspree.astro";
import Card from '@components/common/CardProjects2.astro';
import { Picture } from "astro:assets";
import { fade } from "astro:transitions";

import { Splide, SplideSlide } from 'astro-splide';
import type { Splide as SplideInterface } from 'astro-splide/splide'

const work = (
  await getCollection("workCollection", ({ data }) => data.draft !== true)
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
// get projects and filter later by companySlug
const projects = await getCollection("projectsCollection", ({ data }) => data.draft !== true);
const postsPerPage = 5;

const titleLayout = `Dennis Macapagal - Full-Stack Developer`;
const description = "Minimal and lightweight blog and portfolio.";

---
<Layout title={titleLayout} description={description} ga4={true} clarity={true} maxWidth={false}>
  <section class="bg-grid sm:py-30 py-14  px-4 md:px-0">
    <div class="container max-w-160 mx-auto">
      <h1 class="font-semibold md:text-4xl sm:text-3xl text-2xl text-center" transition:name="heading-1">
        Dennis Macapagal<span class="text-xl">👋🏻</span>
        <div class="w-16 mt-3.75 h-1 bg-green-400/50 rounded mx-auto"></div>
      </h1>
      <div class="my-6">
          <p class="leading-6 text-justify" set:html={introduction.shortDesc}></p>
      </div>
      <div class="my-6">
        <ul class="flex flex-wrap gap-2 justify-center " id="">
          {skills.map((skill) => (
            <li class="flex gap-x-2 text-nowrap notshow fromright -my-0.5 items-center rounded-md px-2.5 py-1.5 text-sm/5 font-medium sm:text-xs/5 forced-colors:outline bg-green-400/20 text-black-700 group-data-hover:bg-green-400/30 dark:bg-green-400/10 dark:text-green-300 dark:group-data-hover:bg-green-400/15">
              {skill.name}
            </li>
          ))}
        </ul>
      </div>
    </div>    
  </section>

   <section class="not-prose z-50 py-8 bg-grid px-4 md:px-0" >
    <div class="container mx-auto">
        <div class="mb-10">
          <h2 class="mt-2 mb-2 text-2xl font-bold">Work <span class=\"text-gray-500\">Experience.</span></h2>
          <div class="w-16 h-1 bg-green-400/50 rounded"></div>
        </div>
        <div class="mx-auto max-w-[90vw] sm:max-w-[95vw] md:max-w-[95vw] lg:max-w-[100vw] min-w-0 ">
          {
            work.map((entry, idx) => (
              <article class="flex flex-col space-y-4 ">
                <div class="flex justify-between items-center gap-2">
                  <div class="xs:flex-1 sm:flex-1 md:flex-1 flex lg:justify-start">
                    <h3 class="text-xl font-medium ">{entry.data.company}</h3>
                  </div>
                   {entry.data.logo && (
                    entry.data.logoIsSVG ? (
                      <div class="w-35 flex justify-end" > <span class="" set:html={entry.data.logo}></span> </div>
                    ) : (
                      <Picture
                        src={entry.data.logo}
                        alt={`${entry.data.company} logo`}
                        class="w-42 h-10 object-contain rounded-md mr-2"
                        width={120}
                        height={60}
                        loading={"lazy"}
                      />
                    )
                  )}
                </div>
                
                <h4 class="text-md font-medium ">{entry.data.role}</h4>
                <div class="text-sm opacity-75">
                  <time datetime={new Date(entry.data.dateStart).toISOString()}>
                    {new Date(entry.data.dateStart).toLocaleDateString(
                      locale.date.locale,
                      locale.date.options,
                    )}
                  </time>
                   - 
                  {new Date(entry.data.dateEnd).getTime() ? (
                  <time datetime={new Date(entry.data.dateEnd).toISOString()}>
                    {new Date(entry.data.dateEnd).toLocaleDateString(
                    locale.date.locale,
                    locale.date.options,
                    )}
                  </time>
                  ) : (
                  <span>Present</span>
                  )}
                </div>
                

                <div set:html={entry.body} class="prose max-w-[100%!important] hidden"></div>

                {
                  // projects that belong to this company (matching companySlug to work entry slug)
                  (() => {
                    const companyProjects = projects.filter((p) => p.data.companySlug === entry.data.companySlug);
                    return companyProjects.length > 0 && (
                      <div class=" min-w-0 ">
                        {companyProjects.length >= 5 ? (
                          <Splide
                            class='not-content overflow-hidden'
                            options={ {
                              perPage: 4,
                              breakpoints: {
                                940: {
                                  perPage: 3,
                                },
                                680: {
                                  perPage: 2,
                                },
                              },
                              rewind: true,
                              gap: '1rem',
                            } }
                            aria-labelledby="basic-example-heading"
                          >
                            {companyProjects.map((p) => (
                              <SplideSlide class="gap-2">
                                <Card
                                  data={p.data}
                                  url={`/projects/${p.id}/`}
                                  slug={p.id}
                                />
                              </SplideSlide>
                            ))}
                          </Splide>
                        ) : (
                          <div class="flex flex-wrap gap-4">
                            {companyProjects.map((p) => (
                              <div class="gap-2">
                                <Card
                                  data={p.data}
                                  url={`/projects/${p.id}/`}
                                  slug={p.id}
                                />
                              </div>
                            ))}
                          </div>
                        )}
                      </div>
                    );
                  })()
                }
                {idx !== work.length - 1 && (
                  <hr class="mt-2.5 mb-2.5 border-b-accent border-gray-300"/>
                )}
              </article>
            ))
          }
          </div>
    </div>
  </section>

  <section class="not-prose z-50 bg-grid2 px-4 md:px-0" >
    <div class="container mx-auto">
      <article class="" transition:name="contact" transition:animate={fade({ duration: "0.4s" })}>
          <ContactFormFormspree  />
      </article>
    </div>
  </section>

</Layout>