---
export const prerender = false;
import Layout from "@/layouts/Layout.astro";
import RandomNumbers from "@/components/RandomNumbers.astro";

const titleLayout = `Dennis Macapagal - Full-Stack Developer`;
const description = "Minimal and lightweight blog and portfolio.";

---
<Layout title={titleLayout} description={description} isDynamic={true} ga4={true} clarity={true} maxWidth={false}>
  <section class=" text-center py-30 px-4 md:px-0">
    <div class="container mx-auto">

      <article class="space-y-4">
          <RandomNumbers />
        </article>
    </div>    
  </section>


</Layout>