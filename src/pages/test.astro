<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dennis - Contact</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* Custom scrollbar matching the dark theme */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #0b111e;
        }
        ::-webkit-scrollbar-thumb {
            background: #1f2937;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #374151;
        }
    </style>
</head>
<body class="bg-[#0b111e] text-slate-200 font-sans min-h-screen selection:bg-indigo-500 selection:text-white">

    <header class="border-b border-slate-800/50 backdrop-blur-md sticky top-0 z-50 bg-[#0b111e]/90">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <a href="#" class="text-2xl font-bold text-white tracking-wide">Dennis</a>
            
            <nav class="hidden md:flex items-center space-x-8 text-sm font-medium text-slate-400">
                <a href="#" class="hover:text-white transition-colors">Work</a>
                <a href="#" class="hover:text-white transition-colors">Services</a>
                <a href="#" class="hover:text-white transition-colors">Process</a>
                <a href="#" class="text-white border-b-2 border-indigo-400 pb-1">Contact</a>
            </nav>

            <button class="bg-[#596ce5] hover:bg-[#4859c7] text-white px-5 py-2.5 rounded text-sm font-semibold transition-all shadow-lg shadow-indigo-600/10">
                Let's Talk
            </button>
        </div>
    </header>

    <aside class="fixed left-4 top-1/3 z-40 hidden lg:flex flex-col gap-4 bg-[#111927] border border-slate-800 p-3 rounded-xl shadow-xl">
        <button class="p-2.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors" title="Portfolio">
            <i data-lucide="folder-kanban" class="w-5 h-5"></i>
        </button>
        <button class="p-2.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors" title="Profile">
            <i data-lucide="user" class="w-5 h-5"></i>
        </button>
        <button class="p-2.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors" title="Share">
            <i data-lucide="share-2" class="w-5 h-5"></i>
        </button>
    </aside>

    <main class="max-w-7xl mx-auto px-6 py-16 md:py-24">
        
        <div class="mb-16">
            <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-4">
                Let's Build Something <span class="text-slate-100">Scalable.</span>
            </h1>
            <div class="w-16 h-1 bg-indigo-400 rounded"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <div class="lg:col-span-5 flex flex-col gap-8">
                
                <div class="flex flex-col gap-6 bg-[#111927]/30 p-2 rounded-2xl">
                    <div class="flex gap-4 items-start">
                        <div class="p-3 bg-[#111927] border border-slate-800 rounded-xl text-indigo-400">
                            <i data-lucide="clock" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <span class="block text-xs font-bold uppercase tracking-widest text-indigo-400">Response Time</span>
                            <span class="text-slate-300 text-sm mt-0.5 block">Replies within 24 hours</span>
                        </div>
                    </div>

                    <div class="flex gap-4 items-start">
                        <div class="p-3 bg-[#111927] border border-slate-800 rounded-xl text-indigo-400">
                            <i data-lucide="globe" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <span class="block text-xs font-bold uppercase tracking-widest text-indigo-400">Timezone</span>
                            <span class="text-slate-300 text-sm mt-0.5 block">Singapore (SGT) — GMT+8</span>
                        </div>
                    </div>

                    <div class="flex gap-4 items-start">
                        <div class="p-3 bg-[#111927] border border-slate-800 rounded-xl text-indigo-400">
                            <i data-lucide="mail" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <span class="block text-xs font-bold uppercase tracking-widest text-indigo-400">Direct Email</span>
                            <a href="mailto:hello@dennis.sgt" class="text-slate-300 text-sm mt-0.5 block hover:text-indigo-400 transition-colors">hello@dennis.sgt</a>
                        </div>
                    </div>
                </div>

                <div class="bg-[#111927] border border-slate-800/80 rounded-2xl p-6 relative overflow-hidden group">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h3 class="text-lg font-bold text-white mb-1">Quick Sync</h3>
                            <p class="text-xs text-slate-400 leading-relaxed max-w-[280px]">
                                Prefer a face-to-face? Book a direct technical discovery call via Cal.com.
                            </p>
                        </div>
                        <span class="text-[10px] font-bold bg-[#1d2d24] text-[#4ade80] px-2 py-0.5 rounded tracking-wide uppercase">30 Min</span>
                    </div>

                    <div class="bg-[#0b111e] border border-dashed border-slate-800 rounded-xl h-44 flex flex-col items-center justify-center gap-3 relative group-hover:border-slate-700 transition-colors">
                        <div class="animate-spin rounded-full h-5 w-5 border-2 border-indigo-500 border-t-transparent opacity-40"></div>
                        <div class="flex flex-col items-center">
                            <i data-lucide="calendar" class="w-6 h-6 text-slate-500 mb-1"></i>
                            <span class="text-xs font-mono text-slate-400 tracking-wider">Cal.com Widget Loading...</span>
                        </div>
                    </div>

                    <button id="openScheduler" class="w-full mt-4 bg-transparent border border-slate-800 hover:border-slate-700 hover:bg-slate-800/40 text-xs font-medium text-slate-300 py-3 rounded-lg tracking-wide transition-all uppercase">
                        Open Scheduler
                    </button>
                </div>
            </div>

            <div class="lg:col-span-7 bg-[#111927] border border-slate-800/80 rounded-2xl p-8 md:p-10">
                <form id="contactForm" class="space-y-6" onsubmit="handleFormSubmit(event)">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-indigo-400 uppercase tracking-widest mb-2">Name</label>
                            <input type="text" placeholder="John Doe" required
                                class="w-full bg-[#0b111e] border border-slate-800 focus:border-indigo-500 focus:outline-none rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-600 transition-colors">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-indigo-400 uppercase tracking-widest mb-2">Email</label>
                            <input type="email" placeholder="john@company.com" required
                                class="w-full bg-[#0b111e] border border-slate-800 focus:border-indigo-500 focus:outline-none rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-600 transition-colors">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="relative">
                            <label class="block text-xs font-bold text-indigo-400 uppercase tracking-widest mb-2">Project Type</label>
                            <div onclick="toggleDropdown('projectDropdown')" class="w-full bg-[#0b111e] border border-slate-800 hover:border-slate-700 rounded-lg px-4 py-3 text-sm text-slate-300 flex justify-between items-center cursor-pointer select-none">
                                <span id="projectSelected">New Website</span>
                                <i data-lucide="chevron-down" class="w-4 h-4 text-slate-500"></i>
                            </div>
                            <div id="projectDropdown" class="hidden absolute left-0 right-0 mt-2 bg-[#111927] border border-slate-800 rounded-lg shadow-2xl z-30 overflow-hidden">
                                <div onclick="selectOption('project', 'New Website')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">New Website</div>
                                <div onclick="selectOption('project', 'Web Application')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">Web Application</div>
                                <div onclick="selectOption('project', 'E-commerce System')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">E-commerce System</div>
                                <div onclick="selectOption('project', 'Consulting / Architecture')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">Consulting / Architecture</div>
                            </div>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-bold text-indigo-400 uppercase tracking-widest mb-2">Budget Range</label>
                            <div onclick="toggleDropdown('budgetDropdown')" class="w-full bg-[#0b111e] border border-slate-800 hover:border-slate-700 rounded-lg px-4 py-3 text-sm text-slate-300 flex justify-between items-center cursor-pointer select-none">
                                <span id="budgetSelected">$5k — $10k</span>
                                <i data-lucide="chevron-down" class="w-4 h-4 text-slate-500"></i>
                            </div>
                            <div id="budgetDropdown" class="hidden absolute left-0 right-0 mt-2 bg-[#111927] border border-slate-800 rounded-lg shadow-2xl z-30 overflow-hidden">
                                <div onclick="selectOption('budget', '< $5k')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">&lt; $5k</div>
                                <div onclick="selectOption('budget', '$5k — $10k')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">$5k — $10k</div>
                                <div onclick="selectOption('budget', '$10k — $25k')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">$10k — $25k</div>
                                <div onclick="selectOption('budget', '$25k+')" class="px-4 py-2.5 text-sm hover:bg-[#0b111e] cursor-pointer text-slate-300 hover:text-white">$25k+</div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-indigo-400 uppercase tracking-widest mb-2">Message</label>
                        <textarea placeholder="Tell me about your technical requirements..." rows="4" required
                            class="w-full bg-[#0b111e] border border-slate-800 focus:border-indigo-500 focus:outline-none rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-600 resize-none transition-colors"></textarea>
                    </div>

                    <div class="pt-2">
                        <button type="submit" class="bg-[#596ce5] hover:bg-[#4859c7] text-white font-semibold text-xs tracking-widest uppercase px-6 py-3.5 rounded transition-all shadow-lg shadow-indigo-600/10">
                            Send Message
                        </button>
                        <p class="text-[11px] text-slate-500 mt-4 leading-relaxed">
                            By sending, you agree to our data processing policy for lead management.
                        </p>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-24 grid grid-cols-1 md:grid-cols-3 gap-6 opacity-30 pointer-events-none">
            <div class="h-44 bg-[#111927] border border-slate-800 rounded-xl p-4 flex flex-col justify-end">
                <div class="w-1/2 h-3 bg-slate-800 rounded mb-2"></div>
                <div class="w-3/4 h-2 bg-slate-800"></div>
            </div>
        </div>

    </main>

</body>
</html>